		"appmanifest": {
			"class": "MediaWiki\\Skins\\Citizen\\Api\\ApiWebappManifest",
			"services": [
				"ContentLanguage",
				"HttpRequestFactory",
				"UrlUtils"
			]
		}
	},
	"HookHandlers": {
		"SkinHooks": {
			"class": "MediaWiki\\Skins\\Citizen\\Hooks\\SkinHooks"
		}
	},
	"Hooks": {
