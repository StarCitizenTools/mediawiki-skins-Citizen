{
	"name": "Citizen",
	"version": "3.14.0",
	"author": [
		"[https://www.mediawiki.org/wiki/User:Alistair3149 Alistair3149]",
		"[https://www.mediawiki.org/wiki/User:Octfx Octfx]",
		"..."
	],
	"url": "https://www.mediawiki.org/wiki/Skin:Citizen",
	"descriptionmsg": "citizen-skin-desc",
	"namemsg": "skinname-citizen",
	"license-name": "GPL-3.0-or-later",
	"type": "skin",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"attributes": {
		"DarkMode": {
			"Disabled": [
				"citizen"
			]
		},
		"VisualEditor": {
			"IconSkins": [
				"citizen"
			]
		}
	},
	"ValidSkinNames": {
		"citizen": {
			"class": "MediaWiki\\Skins\\Citizen\\SkinCitizen",
			"services": [
				"UserFactory",
				"GenderCache",
				"UserIdentityLookup",
				"LanguageConverterFactory",
				"LanguageNameUtils",
				"PermissionManager",
				"UserGroupManager",
				"UrlUtils"
			],
			"optional_services": [
				"MobileFrontend.Context"
			],
			"args": [
				{
					"name": "citizen",
					"responsive": true,
					"supportsMwHeading": true,
					"templateSectionLinks": "SectionLinks",
					"toc": false,
					"wrapSiteNotice": true,
					"link": {
						"text-wrapper": {
							"tag": "span"
						}
					},
					"menus": [
						"user-interface-preferences",
						"user-menu",
						"notifications",
						"views",
						"actions",
						"variants",
						"associated-pages"
					],
					"scripts": [
						"skins.citizen.scripts"
					],
					"styles": [
						"skins.citizen.styles",
						"skins.citizen.codex.styles",
						"skins.citizen.icons"
					],
					"messages": [
						"citizen-actions-more-toggle",
						"citizen-drawer-toggle",
						"citizen-jumptotop",
						"citizen-languages-toggle",
						"citizen-preferences-toggle",
						"citizen-search-toggle",
						"citizen-usermenu-toggle",
						"randompage",
						"search",
						"sitetitle",
						"toc",
						"tooltip-p-logo"
					]
				}
			]
		}
	},
	"SkinLessImportPaths": {
		"citizen": "resources/mediawiki.less"
	},
	"MessagesDirs": {
		"Citizen": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Skins\\Citizen\\": "includes/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Skins\\Citizen\\": "includes/",
		"MediaWiki\\Skins\\Citizen\\Tests\\": "tests/phpunit/"
	},
