{
	"root": true,
	"env": {
		"browser": true,
		"node": true,
		"es2022": true
	},
	"parserOptions": {
		"ecmaVersion": 2022,
		"sourceType": "module"
	},
	"rules": {
		"no-console": "off",
		"strict": "off",
		"n/no-unsupported-features/node-builtins": "off",
		"security/detect-non-literal-fs-filename": "off"
	}
}
